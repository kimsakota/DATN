@model List<DATN.Models.AmbulanceRequest>
@{
    ViewData["Title"] = "Hospital Dashboard";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hospital Dispatcher Dashboard</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', sans-serif; background: #0f1117; color: #e0e0e0; }

        header {
            background: linear-gradient(135deg, #1a237e, #283593);
            padding: 18px 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 12px rgba(0,0,0,0.4);
        }
        header h1 { font-size: 1.5rem; color: #fff; letter-spacing: 1px; }
        .live-dot {
            width: 12px; height: 12px; border-radius: 50%;
            background: #4CAF50;
            animation: pulse 1.5s infinite;
            display: inline-block; margin-right: 8px;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.5; transform: scale(1.3); }
        }

        .stats-bar {
            display: flex; gap: 20px; padding: 20px 30px;
            background: #161b22;
        }
        .stat-card {
            background: #1e2533; border-radius: 12px; padding: 16px 24px;
            flex: 1; text-align: center; border: 1px solid #2d3748;
        }
        .stat-card .num { font-size: 2.2rem; font-weight: 700; }
        .stat-card .label { font-size: 0.85rem; color: #888; margin-top: 4px; }
        .pending-num { color: #ef5350; }
        .dispatched-num { color: #42a5f5; }
        .completed-num { color: #66bb6a; }

        .container { padding: 20px 30px; }
        h2 { font-size: 1.1rem; color: #90caf9; margin: 20px 0 12px; text-transform: uppercase; letter-spacing: 1px; }

        table { width: 100%; border-collapse: collapse; background: #1e2533; border-radius: 12px; overflow: hidden; }
        thead { background: #263147; }
        th { padding: 14px 16px; text-align: left; font-size: 0.8rem; color: #90caf9; text-transform: uppercase; letter-spacing: 0.5px; }
        td { padding: 14px 16px; font-size: 0.9rem; border-bottom: 1px solid #2d3748; vertical-align: middle; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #283147; }

        .badge {
            padding: 4px 12px; border-radius: 20px; font-size: 0.78rem; font-weight: 600;
            display: inline-block;
        }
        .badge-pending    { background: rgba(239,83,80,0.2);  color: #ef5350; border: 1px solid #ef5350; }
        .badge-dispatched { background: rgba(66,165,245,0.2); color: #42a5f5; border: 1px solid #42a5f5; }
        .badge-completed  { background: rgba(102,187,106,0.2);color: #66bb6a; border: 1px solid #66bb6a; }
        .badge-rejected   { background: rgba(158,158,158,0.2);color: #9e9e9e; border: 1px solid #9e9e9e; }

        .action-form { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
        .btn {
            padding: 7px 14px; border: none; border-radius: 8px; cursor: pointer;
            font-size: 0.82rem; font-weight: 600; transition: opacity 0.2s;
        }
        .btn:hover { opacity: 0.85; }
        .btn-dispatch  { background: #1565c0; color: #fff; }
        .btn-arrived   { background: #f57c00; color: #fff; }
        .btn-complete  { background: #2e7d32; color: #fff; }
        .btn-reject    { background: #b71c1c; color: #fff; }

        .empty-state { text-align: center; padding: 60px; color: #555; font-size: 1.1rem; }
        .refresh-bar {
            display: flex; justify-content: flex-end; align-items: center; margin-bottom: 12px; gap: 12px;
        }
        .refresh-bar span { font-size: 0.82rem; color: #888; }
        .btn-refresh { background: #37474f; color: #ccc; padding: 6px 14px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.82rem; }
        .btn-refresh:hover { background: #455a64; }
        #countdown { font-weight: 700; color: #42a5f5; }

        .user-id { font-family: monospace; font-size: 0.8rem; color: #aaa; }
        .time-col { color: #b0bec5; font-size: 0.82rem; }
    </style>
</head>
<body>

<header>
    <div>
        <span class="live-dot"></span>
        <h1 style="display:inline">Hospital Dispatcher Dashboard</h1>
    </div>
    <div style="font-size:0.85rem; color:#90caf9">
        Fall Detection System &nbsp;|&nbsp; Real-time Ambulance Management
    </div>
</header>

<!-- Stats Bar -->
@{
    var pending    = Model.Count(r => r.Status == "Pending");
    var dispatched = Model.Count(r => r.Status == "Dispatched" || r.Status == "Arrived");
    var completed  = Model.Count(r => r.Status == "Completed");
}
<div class="stats-bar">
    <div class="stat-card">
        <div class="num pending-num">@pending</div>
        <div class="label">Cho Xu Ly</div>
    </div>
    <div class="stat-card">
        <div class="num dispatched-num">@dispatched</div>
        <div class="label">Dang Xu Ly</div>
    </div>
    <div class="stat-card">
        <div class="num completed-num">@completed</div>
        <div class="label">Hoan Thanh</div>
    </div>
    <div class="stat-card">
        <div class="num" style="color:#fff">@Model.Count</div>
        <div class="label">Tong Yeu Cau</div>
    </div>
</div>

<div class="container">
    <div class="refresh-bar">
        <span>Tu dong lam moi sau <span id="countdown">30</span>s</span>
        <button class="btn-refresh" onclick="location.reload()">Lam Moi Ngay</button>
    </div>

    <h2>Danh Sach Yeu Cau Cap Cuu</h2>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <p>&#10003; Hien khong co yeu cau cap cuu nao.</p>
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Thoi Gian</th>
                    <th>User ID</th>
                    <th>Vi Tri</th>
                    <th>Trang Thai</th>
                    <th>Ghi Chu</th>
                    <th>Hanh Dong</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var req = Model[i];
                    var badgeClass = req.Status switch {
                        "Pending"    => "badge-pending",
                        "Dispatched" => "badge-dispatched",
                        "Arrived"    => "badge-dispatched",
                        "Completed"  => "badge-completed",
                        _            => "badge-rejected"
                    };
                    <tr>
                        <td>@(i + 1)</td>
                        <td class="time-col">@req.RequestTime.ToString("HH:mm dd/MM/yyyy")</td>
                        <td><span class="user-id">@req.UserId</span></td>
                        <td>@(string.IsNullOrEmpty(req.Location) ? "—" : req.Location)</td>
                        <td><span class="badge @badgeClass">@req.Status</span></td>
                        <td style="max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap"
                            title="@req.DispatchNotes">
                            @(string.IsNullOrEmpty(req.DispatchNotes) ? "—" : req.DispatchNotes)
                        </td>
                        <td>
                            <div class="action-form">
                                @if (req.Status == "Pending")
                                {
                                    <form method="post" action="/Hospital/UpdateStatus" style="display:inline">
                                        <input type="hidden" name="id" value="@req.Id"/>
                                        <input type="hidden" name="status" value="Dispatched"/>
                                        <input type="hidden" name="notes" value="Xe cap cuu da duoc dieu dong"/>
                                        <button type="submit" class="btn btn-dispatch">Dieu Dong</button>
                                    </form>
                                    <form method="post" action="/Hospital/UpdateStatus" style="display:inline">
                                        <input type="hidden" name="id" value="@req.Id"/>
                                        <input type="hidden" name="status" value="Rejected"/>
                                        <input type="hidden" name="notes" value="Tu choi yeu cau"/>
                                        <button type="submit" class="btn btn-reject">Tu Choi</button>
                                    </form>
                                }
                                else if (req.Status == "Dispatched")
                                {
                                    <form method="post" action="/Hospital/UpdateStatus" style="display:inline">
                                        <input type="hidden" name="id" value="@req.Id"/>
                                        <input type="hidden" name="status" value="Arrived"/>
                                        <input type="hidden" name="notes" value="Xe da den noi"/>
                                        <button type="submit" class="btn btn-arrived">Da Den</button>
                                    </form>
                                }
                                else if (req.Status == "Arrived")
                                {
                                    <form method="post" action="/Hospital/UpdateStatus" style="display:inline">
                                        <input type="hidden" name="id" value="@req.Id"/>
                                        <input type="hidden" name="status" value="Completed"/>
                                        <input type="hidden" name="notes" value="Da xu ly xong"/>
                                        <button type="submit" class="btn btn-complete">Hoan Thanh</button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:#555; font-size:0.8rem">—</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<script>
    // Auto-refresh countdown
    let seconds = 30;
    const countdown = document.getElementById('countdown');
    setInterval(() => {
        seconds--;
        if (countdown) countdown.textContent = seconds;
        if (seconds <= 0) location.reload();
    }, 1000);

    // SignalR real-time connection for instant alert
    (async () => {
        try {
            const signalR = await import('https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js');
            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/notification')
                .withAutomaticReconnect()
                .build();

            connection.on('ReceiveNotification', (payload) => {
                if (payload.Type === 'NewAmbulanceRequest') {
                    // Flash the page title and reload immediately
                    document.title = '🚨 YEU CAU MOI! ' + document.title;
                    setTimeout(() => location.reload(), 1500);
                }
            });

            await connection.start();
            await connection.invoke('JoinHospitalGroup');
            console.log('[SignalR] Hospital dashboard connected');
        } catch (e) {
            console.warn('[SignalR] Could not connect:', e);
        }
    })();
</script>

</body>
</html>
